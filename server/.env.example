# --- ArcheryTrade bot ayarları ---
# Sunucu: oyna.chickennw.com (offline)
MC_HOST=oyna.chickennw.com
MC_PORT=25565
MC_USERNAME=ArcheryTrade
MC_AUTH=offline
# Sunucu 1.20 altını kabul etmiyor:
MC_VERSION=1.20.4

# AuthMe şifresi: botun oyunda /kayit ile oluşturduğu şifre. BURAYI DOLDUR.
MC_PASSWORD=
MC_LOGIN_CMD=/login {pass}
# Proxy/lobi ağı: bağlanınca SMP'ye geçiş komutu
MC_SERVER_CMD=/server smpspawn

# Ödeme komutu ve spam-koruma gecikmesi
PAY_COMMAND=/pay {player} {amount}
COMMAND_DELAY_MS=5000

# Komisyon (0.05 = %5)
COMMISSION=0.05

# API
PORT=8787
CLIENT_ORIGIN=http://localhost:5173
