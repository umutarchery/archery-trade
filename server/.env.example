# --- Mineflayer bot ayarları ---
# Boş bırakırsan bot MOCK modda çalışır (gerçek sunucuya bağlanmaz).
# Gerçek sunucuna bağlamak için aşağıyı doldur:

MC_HOST=
MC_PORT=25565
# offline (cracked) sunucu için kullanıcı adı yeter:
MC_USERNAME=KarpuzBot
# online-mode sunucu için Microsoft auth (premium hesap):
MC_AUTH=offline
# MC_AUTH=microsoft

# Minecraft sürümü (boş = otomatik algıla)
MC_VERSION=

# API portu
PORT=8787

# CORS için frontend adresi
CLIENT_ORIGIN=http://localhost:5173
